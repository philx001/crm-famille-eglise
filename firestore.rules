rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/utilisateurs/$(request.auth.uid)).data;
    }

    /** Même famille : string ou DocumentReference (souvent string côté app, ref côté utilisateurs). */
    function sameFamilleId(a, b) {
      return a == b ||
        (a is string && b == /databases/$(database)/documents/familles/$(a)) ||
        (b is string && a == /databases/$(database)/documents/familles/$(b));
    }

    /** Aligné sur l’app : mentor/berger = même niveau ; adjoint_berger = adjoint_superviseur. */
    function roleLevel(role) {
      return role == 'disciple' || role == 'nouveau' ? 1 :
        role == 'mentor' || role == 'berger' ? 2 :
        role == 'adjoint_superviseur' || role == 'adjoint_berger' ? 3 :
        role == 'superviseur' ? 4 :
        role == 'admin' ? 5 : 0;
    }

    function hasRole(role) {
      let userData = getUserData();
      return userData != null && userData.role != null &&
        roleLevel(userData.role) >= roleLevel(role);
    }

    function mentorCanUpdateDisciple() {
      let userData = getUserData();
      return userData != null && userData.famille_id != null && hasRole('mentor') &&
        sameFamilleId(resource.data.famille_id, userData.famille_id) &&
        (resource.data.role == 'disciple' || resource.data.role == 'nouveau');
    }

    function belongsToFamily(familleId) {
      let userData = getUserData();
      return userData != null && (
        userData.role == 'admin' ||
        sameFamilleId(userData.famille_id, familleId)
      );
    }

    /** Mentor « simple » (pas adjoint ni superviseur) — aligné sur hasRole, pas seulement le libellé du rôle. */
    function isMentorPlanningOnly() {
      return hasRole('mentor') && !hasRole('adjoint_superviseur');
    }

    function isAdmin() {
      let u = getUserData();
      return isAuthenticated() && u != null && u.role == 'admin';
    }

    /** dossier_id sur un document : absent, null, ou dossier de la même famille. */
    function documentDossierValidForFamily(familleId, dossierId) {
      return dossierId == null || (
        exists(/databases/$(database)/documents/document_dossiers/$(dossierId)) &&
        sameFamilleId(
          get(/databases/$(database)/documents/document_dossiers/$(dossierId)).data.famille_id,
          familleId
        )
      );
    }

    /** parent_id d’un répertoire : absent, null, ou parent de la même famille. */
    function documentDossierParentValid(familleId, parentId) {
      return parentId == null || (
        exists(/databases/$(database)/documents/document_dossiers/$(parentId)) &&
        sameFamilleId(
          get(/databases/$(database)/documents/document_dossiers/$(parentId)).data.famille_id,
          familleId
        )
      );
    }

    /** Répertoires système racine (non supprimables) : Documents divers, Comptes rendus. */
    function isSystemRootFolderData(data) {
      return data != null && data.keys().hasAny(['system_key']) &&
        (data.system_key == 'documents_divers' || data.system_key == 'comptes_rendus_reunion');
    }

    /** system_key : absent / null pour dossiers normaux ; uniquement DD/CR à la racine à la création. */
    function documentDossierSystemKeyValidOnCreate() {
      let pid = request.resource.data.parent_id;
      let sk = request.resource.data.system_key;
      return sk == null || (
        pid == null && (sk == 'documents_divers' || sk == 'comptes_rendus_reunion')
      );
    }

    /** Bootstrap DD/CR : ID doc = famroot_{famille_id}_documents_divers | famroot_{famille_id}_comptes_rendus_reunion */
    function isSystemRootBootstrapCreate(dossierId) {
      let fid = request.resource.data.famille_id;
      let pid = request.resource.data.parent_id;
      let sk = request.resource.data.system_key;
      return pid == null &&
        (sk == 'documents_divers' || sk == 'comptes_rendus_reunion') &&
        (
          dossierId == 'famroot_' + fid + '_documents_divers' ||
          dossierId == 'famroot_' + fid + '_comptes_rendus_reunion'
        );
    }

    // FAMILLES : lecture sans auth pour la page de connexion (recherche par nom)
    match /familles/{familleId} {
      allow read: if request.auth == null || (isAuthenticated() && belongsToFamily(familleId));
      allow create, update, delete: if isAuthenticated() && isAdmin();
    }

    // UTILISATEURS
    match /utilisateurs/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isAdmin() ||
        (hasRole('superviseur') && sameFamilleId(resource.data.famille_id, getUserData().famille_id)) ||
        (hasRole('mentor') && resource.data.mentor_id == request.auth.uid) ||
        sameFamilleId(resource.data.famille_id, getUserData().famille_id)
      );

      // Création : soit le nouveau compte lui-même, soit un rôle autorisé (même famille ou admin multi-familles)
      allow create: if isAuthenticated() && (
        request.auth.uid == userId ||
        (
          request.resource.data.role != 'admin' &&
          (
            isAdmin() ||
            (hasRole('mentor') && !isAdmin() && sameFamilleId(request.resource.data.famille_id, getUserData().famille_id))
          )
        )
      );

      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        (resource.data.mentor_id == request.auth.uid && (resource.data.role == 'disciple' || resource.data.role == 'nouveau')) ||
        (hasRole('superviseur') && sameFamilleId(resource.data.famille_id, getUserData().famille_id) && resource.data.role != 'admin') ||
        (hasRole('mentor') && resource.data.mentor_id == request.auth.uid) ||
        mentorCanUpdateDisciple() ||
        isAdmin()
      );

      allow delete: if isAuthenticated() && isAdmin();
    }

    // PROGRAMMES
    match /programmes/{programmeId} {
      allow read: if isAuthenticated() && belongsToFamily(resource.data.famille_id);
      allow create, update: if isAuthenticated() &&
        belongsToFamily(request.resource.data.famille_id);
      allow delete: if isAuthenticated() &&
        (hasRole('superviseur') || isAdmin()) &&
        belongsToFamily(resource.data.famille_id);
    }

    // PRÉSENCES (création/modification : tout utilisateur authentifié ; l'app restreint la page aux mentor+)
    match /presences/{presenceId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (hasRole('superviseur') || isAdmin());
    }

    // RÉPERTOIRES DOCUMENTS (création : adjoint+ ; DD/CR racine système non supprimables ; system_key immuable)
    match /document_dossiers/{dossierId} {
      allow read: if isAuthenticated() && belongsToFamily(resource.data.famille_id);
      allow create: if isAuthenticated() && belongsToFamily(request.resource.data.famille_id) &&
        documentDossierParentValid(request.resource.data.famille_id, request.resource.data.parent_id) &&
        (
          (
            hasRole('adjoint_superviseur') &&
            documentDossierSystemKeyValidOnCreate()
          ) ||
          isSystemRootBootstrapCreate(dossierId)
        );
      allow update: if isAuthenticated() && belongsToFamily(resource.data.famille_id) &&
        request.resource.data.famille_id == resource.data.famille_id &&
        documentDossierParentValid(resource.data.famille_id, request.resource.data.parent_id) &&
        request.resource.data.system_key == resource.data.system_key &&
        (
          hasRole('adjoint_superviseur') ||
          resource.data.created_by == request.auth.uid
        );
      allow delete: if isAuthenticated() && belongsToFamily(resource.data.famille_id) &&
        !isSystemRootFolderData(resource.data) && (
          hasRole('adjoint_superviseur') ||
          resource.data.created_by == request.auth.uid
        );
    }

    // DOCUMENTS (fichiers partagés)
    match /documents/{documentId} {
      allow read: if isAuthenticated() && belongsToFamily(resource.data.famille_id);
      allow create: if isAuthenticated() && belongsToFamily(request.resource.data.famille_id) &&
        documentDossierValidForFamily(request.resource.data.famille_id, request.resource.data.dossier_id);
      allow update: if isAuthenticated() && belongsToFamily(resource.data.famille_id) &&
        request.resource.data.famille_id == resource.data.famille_id &&
        documentDossierValidForFamily(resource.data.famille_id, request.resource.data.dossier_id) &&
        (resource.data.uploaded_by == request.auth.uid || hasRole('adjoint_superviseur'));
      allow delete: if isAuthenticated() && belongsToFamily(resource.data.famille_id) && (
        resource.data.uploaded_by == request.auth.uid
        || hasRole('adjoint_superviseur')
      );
    }

    // SUJETS DE PRIÈRE
    match /sujets_priere/{sujetId} {
      allow read: if isAuthenticated() && belongsToFamily(resource.data.famille_id);
      allow create: if isAuthenticated() &&
        belongsToFamily(request.resource.data.famille_id);
      allow update, delete: if isAuthenticated() && (
        resource.data.auteur_id == request.auth.uid || isAdmin()
      );
    }

    // TÉMOIGNAGES (auteur ou admin peut modifier/supprimer)
    match /temoignages/{temoignageId} {
      allow read: if isAuthenticated() && belongsToFamily(resource.data.famille_id);
      allow create: if isAuthenticated() &&
        belongsToFamily(request.resource.data.famille_id);
      allow update, delete: if isAuthenticated() && belongsToFamily(resource.data.famille_id) && (
        resource.data.auteur_id == request.auth.uid || isAdmin()
      );
    }

    // PLANNING CONDUCTEURS PRIÈRE (lecture : toute la famille ; écriture : mentor sur les siens, rôles élevés sur tout)
    match /planning_conducteurs_priere/{slotId} {
      allow read: if isAuthenticated() && belongsToFamily(resource.data.famille_id);
      allow create: if isAuthenticated() &&
        belongsToFamily(request.resource.data.famille_id) &&
        (
          hasRole('adjoint_superviseur') || hasRole('superviseur') || isAdmin() ||
          (isMentorPlanningOnly() && request.resource.data.created_by == request.auth.uid)
        );
      allow update: if isAuthenticated() &&
        belongsToFamily(resource.data.famille_id) &&
        (
          hasRole('adjoint_superviseur') || hasRole('superviseur') || isAdmin() ||
          (
            isMentorPlanningOnly() &&
            resource.data.created_by == request.auth.uid &&
            request.resource.data.created_by == resource.data.created_by
          )
        );
      allow delete: if isAuthenticated() &&
        belongsToFamily(resource.data.famille_id) &&
        (
          hasRole('adjoint_superviseur') || hasRole('superviseur') || isAdmin() ||
          (isMentorPlanningOnly() && resource.data.created_by == request.auth.uid)
        );
    }

    // NOTIFICATIONS (auteur, adjoint_superviseur+, ou admin peut modifier/supprimer)
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && belongsToFamily(resource.data.famille_id);
      allow create: if isAuthenticated() &&
        belongsToFamily(request.resource.data.famille_id);
      allow update, delete: if isAuthenticated() && belongsToFamily(resource.data.famille_id) && (
        resource.data.auteur_id == request.auth.uid || hasRole('adjoint_superviseur') || isAdmin()
      );
    }

    // NOUVELLES ÂMES
    match /nouvelles_ames/{nouvelleAmeId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // SUIVIS DES NOUVELLES ÂMES
    match /suivis_ames/{suiviId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // SESSIONS D'ÉVANGÉLISATION
    match /sessions_evangelisation/{sessionId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // SECTEURS D'ÉVANGÉLISATION
    match /secteurs_evangelisation/{secteurId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // NOTES DE SUIVI
    match /notes_suivi/{noteId} {
      allow read, create, update, delete: if isAuthenticated();
    }

    // NOTES PERSONNELLES (strictement privées : seul l'auteur peut lire/écrire/supprimer)
    match /notes_personnelles/{noteId} {
      allow read: if isAuthenticated() && resource.data.auteur_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.auteur_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.auteur_id == request.auth.uid;
    }

    // LOGS (admin uniquement en lecture)
    match /logs_connexion/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    match /logs_modification/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
